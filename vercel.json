{
    "version": 2,
    "builds": [
        {
            "src": "src/vercel.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "src/vercel.ts"
        },
        {
            "src": "/health",
            "dest": "src/vercel.ts"
        }
    ]
}